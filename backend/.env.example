APP_NAME=WealthOS API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Database (Docker Compose defaults)
DATABASE_URL=postgresql+psycopg://wealthos:wealthos@localhost:5433/wealthos
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_ECHO=false

# Cache / messaging (infra ready; app usage comes later)
REDIS_URL=redis://localhost:6379/0

# Compose helpers
POSTGRES_DB=wealthos
POSTGRES_USER=wealthos
POSTGRES_PASSWORD=wealthos
POSTGRES_PORT=5433
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
