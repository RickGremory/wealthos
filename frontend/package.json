    "nuxt": "^3.21.9",
    "pinia": "^3.0.3",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.9.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.3.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.34.0",
    "happy-dom": "^18.0.1",
    "openapi-typescript": "^6.7.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.6"
  }
